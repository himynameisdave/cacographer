{
	"$schema": "./node_modules/oxlint/configuration_schema.json",
	"plugins": ["typescript", "unicorn", "oxc", "import", "promise", "node", "jsdoc"],
	"categories": {
		"correctness": "error",
		"suspicious": "error",
		"pedantic": "error",
		"perf": "error",
		"style": "error"
	},
	"env": {
		"browser": true,
		"es2024": true
	},
	"ignorePatterns": ["build", ".svelte-kit", "node_modules"],
	"rules": {
		"eslint/sort-keys": "off",
		"eslint/id-length": "off",
		"eslint/no-ternary": "off",
		"eslint/no-continue": "off",
		"eslint/no-magic-numbers": "off",
		"eslint/no-inline-comments": "off",
		"eslint/capitalized-comments": "off",
		"eslint/func-style": "off",
		"eslint/max-statements": "off",
		"eslint/max-lines": "off",
		"eslint/max-lines-per-function": "off",
		"eslint/sort-imports": "off",
		"eslint/init-declarations": "off",
		"unicorn/no-null": "off",
		"unicorn/filename-case": [
			"error",
			{ "cases": { "kebabCase": true, "camelCase": true, "pascalCase": true } }
		],
		"import/consistent-type-specifier-style": ["error", "prefer-inline"],
		"import/no-unassigned-import": ["error", { "allow": ["**/*.css"] }],
		"import/max-dependencies": ["error", { "max": 24 }],
		"eslint/max-params": ["error", { "max": 5 }],
		"import/no-named-export": "off",
		"import/group-exports": "off",
		"import/exports-last": "off",
		"import/no-nodejs-modules": "off",
		"import/prefer-default-export": "off",
		"typescript/parameter-properties": "off",
		"node/no-sync": "off",
		"typescript/consistent-type-definitions": ["error", "type"],
		"unicorn/prefer-set-has": "error",

		// Type-aware rules: require `--type-aware` (see package.json `lint` script) and the
		// `oxlint-tsgolint` devDependency.
		"typescript/prefer-readonly-parameter-types": "error",
		"typescript/prefer-readonly": "error",
		"typescript/no-confusing-void-expression": "error",
		"typescript/no-unnecessary-condition": "error",
		"typescript/no-unnecessary-type-assertion": "error",
		"typescript/no-redundant-type-constituents": "error",
		"typescript/no-misused-spread": "error",
		"typescript/switch-exhaustiveness-check": "error",
		"typescript/prefer-nullish-coalescing": "error",
		"typescript/non-nullable-type-assertion-style": "error",
		"typescript/prefer-regexp-exec": "error",

		// oxlint's jsdoc plugin has no "require a JSDoc block exists" rule — exported functions
		// getting a one-line description (see server/engine/scoring.ts) is a code-review
		// expectation (CLAUDE.md), not something lint can gate. The category defaults above turn
		// on the whole jsdoc plugin, including require-param/require-returns, which force full
		// `@param`/`@returns` tag blocks onto every function with so much as a one-line doc
		// comment — that would push this codebase's terse style toward verbose Javadoc-style
		// comments CLAUDE.md explicitly avoids, so those are off. check-tag-names stays on to
		// catch typos/unrecognized tags in whatever JSDoc already exists.
		"jsdoc/check-tag-names": "error",
		"jsdoc/require-param": "off",
		"jsdoc/require-param-description": "off",
		"jsdoc/require-param-name": "off",
		"jsdoc/require-param-type": "off",
		"jsdoc/require-property": "off",
		"jsdoc/require-property-description": "off",
		"jsdoc/require-property-name": "off",
		"jsdoc/require-property-type": "off",
		"jsdoc/require-returns": "off",
		"jsdoc/require-returns-description": "off",
		"jsdoc/require-returns-type": "off",
		"jsdoc/require-throws-description": "off",
		"jsdoc/require-throws-type": "off",
		"jsdoc/require-yields": "off",
		"jsdoc/require-yields-description": "off",
		"jsdoc/require-yields-type": "off"
	},
	"overrides": [
		{
			"files": ["**/*.svelte"],
			"rules": {
				"eslint/prefer-const": "off"
			}
		},
		{
			"files": ["server/engine/*.test.ts", "server/engine/testUtils.ts"],
			"rules": {
				"typescript/no-explicit-any": "off",
				"typescript/no-non-null-assertion": "off",
				"eslint/max-classes-per-file": "off",
				// The engine validates untrusted wire JSON, so its tests have to construct payloads
				// that violate the static contract on purpose (e.g. an unknown `wordSource`) — the
				// assertion is the test. Same reasoning as no-explicit-any above.
				"typescript/no-unsafe-type-assertion": "off"
			}
		},
		{
			// The transport boundary: `Socket` (Bun's `ServerWebSocket<SocketData>`) and `Buffer`
			// are classes with inherently mutable members, so no wrapper makes them deeply
			// readonly and every handler here has to take one. Exempting the two types keeps the
			// rule enforcing on everything else in the file rather than switching it off wholesale.
			"files": ["server/index.ts"],
			"rules": {
				"typescript/prefer-readonly-parameter-types": [
					"error",
					{ "allow": ["Socket", { "from": "package", "package": "@types/node", "name": "Buffer" }] }
				]
			}
		}
	]
}
